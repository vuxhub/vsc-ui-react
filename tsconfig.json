{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowArbitraryExtensions": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "src",
    "test",
    "playground",
    ".storybook",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
