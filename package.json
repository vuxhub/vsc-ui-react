{
  "name": "vsc-ui-react",
  "version": "1.0.1",
  "description": "VS Code styled Fluent UI components for React.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev": "vite",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build -o storybook-static",
    "prepublishOnly": "npm run build && npm run typecheck && npm run lint && npm run test"
  },
  "peerDependencies": {
    "@fluentui/react-components": "^9.57.0",
    "@fluentui/react-icons": "^2.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fluentui/react-components": "^9.57.0",
    "@fluentui/react-icons": "^2.0.320",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "storybook": "^10.3.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vitest": "^3.0.5",
    "eslint-plugin-storybook": "10.3.6",
    "@storybook/addon-docs": "^10.3.6"
  },
  "keywords": [
    "react",
    "fluent-ui",
    "vscode",
    "component-library",
    "button",
    "input",
    "textarea",
    "dropdown",
    "combobox",
    "menu",
    "searchbox",
    "field"
  ],
  "license": "MIT"
}
